{
  "name": "aria-image-viewer",
  "version": "1.0.0",
  "description": "ARIA Image Viewer - Visor de imágenes universal con conversión y edición",
  "main": "main.js",
  "homepage": "https://github.com/aria/aria-image-viewer",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:deb": "electron-builder --linux deb",
    "build:appimage": "electron-builder --linux AppImage",
    "build:rpm": "electron-builder --linux rpm"
  },
  "keywords": [
    "image",
    "viewer",
    "electron",
    "converter"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "electron-store": "^8.2.0",
    "sharp": "^0.32.6"
  },
  "build": {
    "appId": "com.aria.imageviewer",
    "productName": "ARIA Image Viewer",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!dist/**"
    ],
    "linux": {
      "target": [
        "deb",
        "AppImage",
        "rpm"
      ],
      "category": "Graphics",
      "maintainer": "ARIA Team",
      "icon": "build",
      "mimeTypes": [
        "image/jpeg",
        "image/png",
        "image/gif",
        "image/bmp",
        "image/webp",
        "image/svg+xml",
        "image/tiff",
        "image/x-icon"
      ]
    }
  }
}
